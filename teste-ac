<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Teste Autocomplete</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
body{font-family:sans-serif;padding:20px;background:#F8FAFC}
.wrap{position:relative;max-width:400px}
input{width:100%;padding:12px 16px;font-size:16px;border:2px solid #E2E8F0;border-radius:10px;outline:none;box-sizing:border-box}
input:focus{border-color:#2563EB}
.drop{position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border:1px solid #E2E8F0;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.1);z-index:99;display:none}
.drop.open{display:block}
.item{padding:12px 16px;cursor:pointer;font-size:14px;border-bottom:1px solid #F8FAFC}
.item:last-child{border-bottom:none}
.item:active{background:#EFF6FF}
#status{margin-bottom:12px;padding:10px;border-radius:8px;font-size:13px;background:#DBEAFE;color:#1E40AF}
#resultado{margin-top:16px;padding:12px;background:#DCFCE7;border-radius:8px;font-size:14px;font-weight:600;display:none}
</style>
</head>
<body>
<div id="status">Carregando...</div>
<div class="wrap">
  <input id="busca" type="text" placeholder="Digite o nome do cliente..." oninput="buscar()" onkeyup="buscar()" autocomplete="off"/>
  <div class="drop" id="drop"></div>
</div>
<div id="resultado"></div>

<script>
const URL='https://suwaqkxkhhfopjkhsptf.supabase.co';
const KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN1d2Fxa3hraGhmb3Bqa2hzcHRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4MDI2MDQsImV4cCI6MjA5MDM3ODYwNH0.HcLs3bkZZ0lATGSQbWtTt7oIxcM8inYmLZHm2K5v39U';
const db=supabase.createClient(URL,KEY,{global:{fetch:(...a)=>fetch(...a)}});
let lista=[];

async function init(){
  const{data,error}=await db.from('clientes').select('id,nome,cidade').order('nome');
  if(error){
    document.getElementById('status').textContent='ERRO: '+error.message;
    document.getElementById('status').style.background='#FEE2E2';
    document.getElementById('status').style.color='#991B1B';
  }else{
    lista=data||[];
    document.getElementById('status').textContent='✅ '+lista.length+' clientes carregados!';
    document.getElementById('status').style.background='#DCFCE7';
    document.getElementById('status').style.color='#166534';
  }
}

function buscar(){
  const q=document.getElementById('busca').value.toLowerCase().trim();
  const drop=document.getElementById('drop');
  if(!q){drop.classList.remove('open');return;}
  const r=lista.filter(c=>c.nome.toLowerCase().includes(q)).slice(0,6);
  if(!r.length){drop.classList.remove('open');return;}
  drop.innerHTML=r.map(c=>`<div class="item" ontouchend="selecionar('${c.id}');event.preventDefault()" onclick="selecionar('${c.id}')">${c.nome}<br/><small style="color:#94A3B8">${c.cidade}</small></div>`).join('');
  drop.classList.add('open');
}

function selecionar(id){
  const c=lista.find(x=>x.id===id);
  if(!c)return;
  document.getElementById('busca').value=c.nome;
  document.getElementById('drop').classList.remove('open');
  const r=document.getElementById('resultado');
  r.textContent='✅ Selecionado: '+c.nome+' - '+c.cidade;
  r.style.display='block';
}

document.addEventListener('touchstart',e=>{
  if(!e.target.closest('.wrap')) document.getElementById('drop').classList.remove('open');
},{passive:true});
document.addEventListener('click',e=>{
  if(!e.target.closest('.wrap')) document.getElementById('drop').classList.remove('open');
});

init();
</script>

</body>
</html>
