<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Teste Clientes</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
body{font-family:sans-serif;padding:20px;background:#F8FAFC}
input{width:100%;padding:12px;font-size:16px;border:2px solid #E2E8F0;border-radius:8px;margin-bottom:10px;box-sizing:border-box}
.item{padding:10px;background:#fff;border:1px solid #E2E8F0;border-radius:8px;margin-bottom:6px}
#status{padding:10px;background:#DBEAFE;border-radius:8px;margin-bottom:10px;font-size:13px}
</style>
</head>
<body>

<div id="status">Carregando...</div>
<input id="busca" type="text" placeholder="Digite o nome do cliente..." oninput="filtrar()"/>
<div id="lista"></div>

<script>
const SUPA_URL='https://suwaqkxkhhfopjkhsptf.supabase.co';
const SUPA_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN1d2Fxa3hraGhmb3Bqa2hzcHRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4MDI2MDQsImV4cCI6MjA5MDM3ODYwNH0.HcLs3bkZZ0lATGSQbWtTt7oIxcM8inYmLZHm2K5v39U';
const db = supabase.createClient(SUPA_URL, SUPA_KEY);

let todos = [];

async function init(){
  document.getElementById('status').textContent = 'Buscando clientes...';
  const {data, error} = await db.from('clientes').select('id,nome,cidade').order('nome');
  if(error){
    document.getElementById('status').textContent = 'ERRO: ' + error.message;
    document.getElementById('status').style.background = '#FEE2E2';
    return;
  }
  todos = data || [];
  document.getElementById('status').textContent = '✅ ' + todos.length + ' clientes carregados!';
  document.getElementById('status').style.background = '#DCFCE7';
  filtrar();
}

function filtrar(){
  const q = document.getElementById('busca').value.toLowerCase();
  const filtro = q ? todos.filter(c=>c.nome.toLowerCase().includes(q)) : todos.slice(0,10);
  document.getElementById('lista').innerHTML = filtro.map(c=>`
    <div class="item"><strong>${c.nome}</strong><br/><small>${c.cidade}</small></div>
  `).join('');
}

init();
</script>

</body>
</html>
