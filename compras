<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
<title>HuberHorti - Compras v25.9</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="supabase.js"></script>
<script src="utils.js"></script>

<style>
/* RESET & BASE */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{
    font-family:'Inter',sans-serif;
    background:#F2F4F8;
    color:#1C1C1E;
    height: 100vh; 
    height: calc(var(--vh, 1vh) * 100);
    display:flex;
    flex-direction:column;
    overflow:hidden;
}

/* TOPBAR */
.topbar{
    height: 64px;
    padding: 0 18px;
    padding-top: env(safe-area-inset-top);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.topbar-copy{display:flex;flex-direction:column;align-items:center;text-align:center;flex-grow:1}
.breadcrumb .active{color:#1C1C1E;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.8px}
.autosave-status{font-size:10px;color:#10B981;font-weight:500;transition: color 0.3s ease;}

/* ÁREA PRINCIPAL */
.main{
    flex-shrink: 0;
    padding: 0 16px; 
    display: flex;
    flex-direction: column;
}

.unified-card {
    background: #FFF;
    border-radius: 28px;
    box-shadow: 0 2px 10px rgba(0,0,0,.02);
    flex-shrink: 0;
    overflow: visible !important; 
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    z-index: 100;
}

/* AUTOCOMPLETE */
.autocomplete-wrapper { position: relative; width: 100%; }
.autocomplete-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #FFF;
    border-radius: 18px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    z-index: 9999;
    max-height: 220px;
    overflow-y: auto;
    display: none;
    margin-top: 8px;
    border: 1px solid #F2F2F7;
}

.card-search-section { padding: 14px 14px 8px 14px; }
.busca-wrap-ios {
    position: relative;
    display: flex;
    align-items: center;
    background: #F8F8FA;
    border-radius: 16px;
    padding: 4px 10px;
}
.busca-input {
    flex-grow: 1;
    padding: 8px 8px 8px 32px;
    background: transparent;
    border: none;
    font-size: 15px;
    outline: none;
    color: #1C1C1E;
}
.busca-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    stroke: #8E8E93;
    stroke-width: 2.5;
    fill: none;
}

/* TOTAL E AÇÕES */
.total-info-section { 
    padding: 4px 18px 14px 18px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
}
.total-label { font-size: 9px; font-weight: 700; color: #8E8E93; text-transform: uppercase; margin-bottom: 2px; display: block; }
.price-tag { font-size: 18px; font-weight: 700; color: #1C1C1E; letter-spacing: -0.5px; }

.card-actions { display: flex; gap: 8px; align-items: center; }
.btn-card-action {
    width: 32px; height: 32px; border-radius: 50%; border: none;
    background: #F2F2F7; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s ease;
    cursor: pointer;
}
.btn-card-action svg { width: 14px; height: 14px; stroke: #1C1C1E; stroke-width: 2.5; fill: none; }
.btn-card-action.expand-btn { transition: transform 0.3s ease; }
.unified-card.expanded .expand-btn { transform: rotate(180deg); }

/* SUMÁRIO EXPANSÍVEL */
.details-content {
    max-height: 0;
    opacity: 0;
    padding: 0 18px;
    transition: all 0.4s ease;
    overflow: hidden;
}
.unified-card.expanded .details-content {
    max-height: 250px;
    opacity: 1;
    padding-bottom: 20px;
    border-top: 1px solid #F3F4F6;
    padding-top: 15px;
}

.details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.sumario-titulo { font-size: 11px; font-weight: 600; color: #1C1C1E; margin-bottom: 12px; display: block; }
.detail-item { font-size: 11px; color: #8E8E93; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
.detail-item b { color: #1C1C1E; }

/* SELETOR DE VISÃO */
.view-selector { display: flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 700; color: #C7C7CC; }
.view-opt { cursor: pointer; transition: color 0.2s; padding: 2px 4px; }
.view-opt.active { color: #007AFF; }
.col-hidden { display: none !important; }

/* GRID TABELA */
.footer-grid-card {
    background: #FFF; 
    border-radius: 32px 32px 0 0;
    box-shadow: 0 -4px 15px rgba(0,0,0,.05);
    display: flex; 
    flex-direction: column;
    flex: 1; 
    min-height: 0; 
    margin-top: 12px;
    overflow: hidden;
}
.grid-scroll { flex: 1; overflow: auto; }
table { border-collapse: collapse; width: max-content; font-size: 10px; table-layout: fixed; }
th, td { padding: 12px 8px; text-align: center; border-bottom: 1px solid #F9FAFB; color: #1C1C1E; width: 75px; }
th:first-child, td:first-child { 
    width: 150px; position: sticky; left: 0; background: #FFF; 
    text-align: left; font-weight: 700; z-index: 5; border-right: 1px solid #F3F4F6; padding-left: 20px;
}
thead th { position: sticky; top: 0; background: #F9FAFB; z-index: 10; border-bottom: 1px solid #F3F4F6; color: #8E8E93; }

.grid-input {
    width: 100%; border: 1px solid #E5E5EA; border-radius: 6px; padding: 5px;
    text-align: center; font-size: 10px; background: #F9FAFB; outline: none; font-weight: 600;
}
.grid-input[readonly] { background: transparent; border-color: transparent; }

.pagination-footer {
  flex-shrink: 0; height: 65px; padding: 0 20px calc(8px + env(safe-area-inset-bottom));
  background: #FFF; border-top: 1px solid #F3F4F6; display: flex; justify-content: space-between; align-items: center;
}
.ios-btn-float { width: 38px; height: 38px; border-radius: 50%; border: none; background: #FFF; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }

/* ESTADOS DE UI */
.btn-disabled { opacity: 0.4; pointer-events: none; }
</style>
</head>
<body>

<div class="topbar">
  <button class="ios-btn-float" onclick="history.back()">
    <svg viewBox="0 0 24 24" style="width:18px; height:18px; stroke:#1C1C1E; stroke-width:2.2; fill:none"><path d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
  </button>
  <div class="topbar-copy">
    <div class="breadcrumb"><span class="active">Central de Compras</span></div>
    <div class="autosave-status" id="status-sinc">Sincronizado</div>
  </div>
  <button class="ios-btn-float">
    <svg viewBox="0 0 24 24" style="width:18px; height:18px; stroke:#1C1C1E; stroke-width:2.2; fill:none"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0 M12 8v8 M8 12h8"/></svg>
  </button>
</div>

<div class="main">
  <div class="unified-card" id="mainCard">
    <div class="card-search-section">
      <div class="autocomplete-wrapper">
        <div class="busca-wrap-ios">
          <svg class="busca-icon" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <input id="busca-fornecedor" class="busca-input" type="text" placeholder="Buscar Fornecedor..." autocomplete="off">
        </div>
        <div id="resultados-fornecedor" class="autocomplete-results"></div>
      </div>
    </div>

    <div class="total-info-section">
      <div onclick="toggleCard()" style="flex-grow: 1; cursor: pointer;">
        <span class="total-label">Total da Compra</span>
        <div style="display:flex; align-items:center">
          <span class="price-tag" id="total-geral">R$ 0,00</span>
          <div id="badge-ganho" style="padding:1px 6px;background:#E1F9F0;color:#10B981;border-radius:6px;font-size:9px;font-weight:700;margin-left:8px; display:none">0%</div>
        </div>
      </div>
      
      <div class="card-actions">
        <button class="btn-card-action" id="btn-gravar" title="Gravar Compra" onclick="salvarCompra()">
          <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        </button>
        <button class="btn-card-action" id="btn-incluir" title="Nova Compra"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
        <button class="btn-card-action" id="btn-excluir" title="Excluir Compra"><svg viewBox="0 0 24 24"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6"/></svg></button>
        <button class="btn-card-action expand-btn" onclick="toggleCard()"><svg viewBox="0 0 24 24"><path d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg></button>
      </div>
    </div>

    <div class="details-content">
      <span class="sumario-titulo">Sumário da Compra</span>
      <div class="details-grid">
        <div>
          <div class="detail-item">Data: <input type="date" id="data-ciclo" style="border:none; background:transparent; font-weight:700; text-align:right; outline:none"></div>
          <div class="detail-item">Número: <b id="num-compra">#-----</b></div>
          <div class="detail-item">
             <div class="view-selector">
                <span class="view-opt active" id="opt-qt1" onclick="setViewMode('QT1')">QT1</span>
                <span>•</span>
                <span class="view-opt" id="opt-qt2" onclick="setViewMode('QT2')">QT2</span>
             </div>
             <b id="qtd-itens">0</b>
          </div>
        </div>
        <div>
          <div class="detail-item">Total: <b id="subtotal-card">R$ 0,00</b></div>
          <div class="detail-item">Ganho: <b id="ganho-card" style="color:#10B981">R$ 0,00</b></div>
          <div class="detail-item">Status: <b>Aberto</b></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="footer-grid-card">
  <div class="grid-scroll">
    <table id="tabela-produtos">
      <thead>
        <tr>
          <th>PRODUTOS</th>
          <th>EST INI</th>
          <th>CT. INI</th>
          <th class="th-qt1">QT1</th>
          <th class="th-qt2 col-hidden">QT2</th>
          <th>COMP</th>
          <th>CUST</th>
          <th>MKT</th>
          <th>PM</th>
          <th>T1</th>
          <th>T2</th>
          <th>GAN</th>
        </tr>
      </thead>
      <tbody id="corpo-grid"></tbody>
    </table>
  </div>
  <div class="pagination-footer">
    <span id="info-pag" style="font-size:10px; color:#8E8E93; font-weight:600">Selecione um fornecedor</span>
  </div>
</div>

<script>
window.HHUtils.atualizarCicloAtualGlobal();
let currentView = 'QT1';
let estaEditando = false;

const setupDataDefault = () => {
    const campoData = document.getElementById('data-ciclo');
    const hoje = new Date();
    hoje.setDate(hoje.getDate() + 1); 
    campoData.value = hoje.toISOString().split('T')[0];
};
setupDataDefault();

// MÁQUINA DE ESTADOS DA UI
function setUiState(state) {
    const btnGravar = document.getElementById('btn-gravar');
    const btnIncluir = document.getElementById('btn-incluir');
    const btnExcluir = document.getElementById('btn-excluir');
    const statusEl = document.getElementById('status-sinc');

    switch(state) {
        case 'pendente':
            statusEl.textContent = "Alterações pendentes...";
            statusEl.style.color = "#F59E0B";
            estaEditando = true;
            break;
        case 'gravando':
            statusEl.textContent = "Gravando no banco...";
            statusEl.style.color = "#8E8E93";
            [btnGravar, btnIncluir, btnExcluir].forEach(b => b.classList.add('btn-disabled'));
            break;
        case 'sucesso':
            statusEl.textContent = "Sincronizado";
            statusEl.style.color = "#10B981";
            [btnGravar, btnIncluir, btnExcluir].forEach(b => b.classList.remove('btn-disabled'));
            estaEditando = false;
            break;
        case 'erro':
            statusEl.textContent = "Erro na gravação!";
            statusEl.style.color = "#EF4444";
            [btnGravar, btnIncluir, btnExcluir].forEach(b => b.classList.remove('btn-disabled'));
            break;
    }
}

function setViewMode(mode) {
    currentView = mode;
    document.getElementById('opt-qt1').classList.toggle('active', mode === 'QT1');
    document.getElementById('opt-qt2').classList.toggle('active', mode === 'QT2');
    document.querySelector('.th-qt1').classList.toggle('col-hidden', mode !== 'QT1');
    document.querySelector('.th-qt2').classList.toggle('col-hidden', mode !== 'QT2');
    atualizarSumario();
}

const inputBusca = document.getElementById('busca-fornecedor');
const listaResultados = document.getElementById('resultados-fornecedor');
const corpoGrid = document.getElementById('corpo-grid');

inputBusca.addEventListener('input', async (e) => {
    const termo = e.target.value;
    if (termo.length < 1) { listaResultados.style.display = 'none'; return; }
    const { data } = await window.db.from('fornecedores').select('id, codigo, nome').ilike('nome', `%${termo}%`).limit(10);
    if (data) {
        listaResultados.innerHTML = data.map(f => `<div class="autocomplete-item" onclick="selecionarFornecedor('${f.nome}', '${f.id}')">${f.nome}</div>`).join('');
        listaResultados.style.display = 'block';
    }
});

async function selecionarFornecedor(nome, id) {
    inputBusca.value = nome;
    inputBusca.dataset.selectedId = id;
    listaResultados.style.display = 'none';
    await carregarProdutosEstoque(id);
}

function atualizarSumario() {
    const linhas = document.querySelectorAll('#corpo-grid tr');
    let somaT1 = 0, somaGAN = 0, contador = 0;
    linhas.forEach(tr => {
        const valAtivo = currentView === 'QT1' ? parseFloat(tr.querySelector('.td-qt1').textContent) : parseFloat(tr.querySelector('.td-qt2').textContent);
        tr.querySelector('.td-qt1').classList.toggle('col-hidden', currentView !== 'QT1');
        tr.querySelector('.td-qt2').classList.toggle('col-hidden', currentView !== 'QT2');
        if (valAtivo > 0) {
            tr.style.display = 'table-row';
            somaT1 += parseFloat(tr.querySelector('.col-t1-input').value) || 0;
            somaGAN += parseFloat(tr.querySelector('.col-ganho-input').value) || 0;
            contador++;
        } else { tr.style.display = 'none'; }
    });
    document.getElementById('total-geral').textContent = somaT1.toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
    document.getElementById('subtotal-card').textContent = somaT1.toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
    document.getElementById('ganho-card').textContent = somaGAN.toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
    document.getElementById('qtd-itens').textContent = contador;
}

corpoGrid.addEventListener('input', (e) => {
    if (e.target.classList.contains('grid-input')) {
        if (!estaEditando) setUiState('pendente');
        const tr = e.target.closest('tr');
        const comp = parseFloat(tr.querySelector('.col-comp').value) || 0;
        const cust = parseFloat(tr.querySelector('.col-custo-input').value) || 0;
        const mkt = parseFloat(tr.querySelector('.col-mkt-input').value) || 0;
        const estIni = parseFloat(tr.querySelector('.col-est-ini').textContent) || 0;
        const ctIni = parseFloat(tr.querySelector('.col-ct-ini').textContent) || 0;

        const pm = (comp + estIni) > 0 ? ((mkt * comp) + (estIni * ctIni)) / (comp + estIni) : 0;
        tr.querySelector('.col-pm').textContent = pm.toFixed(2);
        tr.querySelector('.col-t1-input').value = (comp * cust).toFixed(2);
        tr.querySelector('.col-t2-input').value = (comp * mkt).toFixed(2);
        tr.querySelector('.col-ganho-input').value = ((comp * mkt) - (comp * cust)).toFixed(2);
        atualizarSumario();
    }
});

async function carregarProdutosEstoque(fornecedorUuid) {
    const { data: produtos } = await window.db.from('produtos').select(`id, nome, estoque_inicial (quantidade_inicial, custo_unitario_inicial)`).eq('fornecedor_id', fornecedorUuid).order('nome');
    if (produtos) {
        corpoGrid.innerHTML = produtos.map(p => {
            const est = p.estoque_inicial?.[0]?.quantidade_inicial || 0;
            const ct = p.estoque_inicial?.[0]?.custo_unitario_inicial || 0;
            return `<tr data-id="${p.id}">
                <td>${p.nome}</td><td class="col-est-ini">${est}</td><td class="col-ct-ini">${ct.toFixed(2)}</td>
                <td class="td-qt1">0</td><td class="td-qt2 col-hidden">0</td>
                <td><input type="number" class="grid-input col-comp" value="0"></td>
                <td><input type="number" class="grid-input col-custo-input" value="0.00"></td>
                <td><input type="number" class="grid-input col-mkt-input" value="0.00"></td>
                <td class="col-pm">${ct.toFixed(2)}</td>
                <td><input type="number" class="grid-input col-t1-input" value="0.00" readonly></td>
                <td><input type="number" class="grid-input col-t2-input" value="0.00" readonly></td>
                <td><input type="number" class="grid-input col-ganho-input" value="0.00" readonly style="color:#10B981"></td>
            </tr>`;
        }).join('');
        atualizarSumario();
    }
}

async function salvarCompra() {
    const fid = inputBusca.dataset.selectedId;
    const total = parseFloat(document.getElementById('total-geral').textContent.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
    const linhas = Array.from(document.querySelectorAll('#corpo-grid tr')).filter(tr => (parseFloat(tr.querySelector('.col-comp').value) || 0) > 0);

    if (!fid || linhas.length === 0) { alert("Selecione fornecedor e preencha itens."); return; }

    setUiState('gravando');
    try {
        const { data: ped, error: errP } = await window.db.from('pedidos_compras').insert([{ fornecedor_id: fid, data: document.getElementById('data-ciclo').value, valor_total: total, em_aberto: total }]).select().single();
        if (errP) throw errP;

        const promessas = [];
        linhas.forEach(tr => {
            const comp = parseFloat(tr.querySelector('.col-comp').value);
            const cust = parseFloat(tr.querySelector('.col-custo-input').value);
            const mkt = parseFloat(tr.querySelector('.col-mkt-input').value);
            const pm = parseFloat(tr.querySelector('.col-pm').textContent);

            promessas.push(window.db.from('itens_pedidos_compras').insert([{ pedido_compra_id: ped.id, produto_id: tr.dataset.id, quantidade: comp, preco_unitario: cust, preco_compra_mkt: mkt, valor_total: (comp*cust), ganho: (comp*mkt)-(comp*cust) }]));
            promessas.push(window.db.from('produtos').update({ preco_medio_compra: pm }).eq('id', tr.dataset.id));
        });

        await Promise.all(promessas);
        setUiState('sucesso');
        document.getElementById('num-compra').textContent = `#${ped.id.toString().slice(-4)}`;
        alert("Salvo!");
    } catch (e) { setUiState('erro'); }
}

function toggleCard() { document.getElementById('mainCard').classList.toggle('expanded'); }
</script>
</body>
</html>
