<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
<title>HuberHorti - Compras v25.9</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="supabase.js"></script>
<script src="utils.js"></script>

<style>
/* CSS ORIGINAL PRESERVADO */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{
    font-family:'Inter',sans-serif;
    background:#F2F4F8;
    color:#1C1C1E;
    height: 100vh; 
    height: calc(var(--vh, 1vh) * 100);
    display:flex;
    flex-direction:column;
    overflow:hidden;
}

/* APENAS O ESTILO DA PÍLULA INJETADO */
.pill-ganho {
    padding: 2px 8px;
    border-radius: 50px;
    font-size: 10px;
    font-weight: 800;
    margin-left: 8px;
    display: none;
    transition: all 0.3s ease;
}
.pill-ganho.positivo { background: #E1F9F0 !important; color: #10B981 !important; }
.pill-ganho.negativo { background: #FEE2E2 !important; color: #EF4444 !important; }

/* ESTILOS DE INTERFACE */
.topbar{ height: 64px; padding: 0 18px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
.topbar-copy{display:flex;flex-direction:column;align-items:center;flex-grow:1}
.breadcrumb .active{color:#1C1C1E;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:0.8px}
.autosave-status{font-size:10px;color:#10B981;font-weight:500;}

.main{ flex-shrink: 0; padding: 0 16px; display: flex; flex-direction: column; }
.unified-card { background: #FFF; border-radius: 28px; box-shadow: 0 2px 10px rgba(0,0,0,.02); flex-shrink: 0; position: relative; z-index: 100; }

.card-search-section { padding: 14px 14px 8px 14px; }
.busca-wrap-ios { position: relative; display: flex; align-items: center; background: #F8F8FA; border-radius: 16px; padding: 4px 10px; }
.busca-input { flex-grow: 1; padding: 8px 8px 8px 32px; background: transparent; border: none; font-size: 15px; outline: none; }

.total-info-section { padding: 4px 18px 14px 18px; display: flex; justify-content: space-between; align-items: center; }
.total-label { font-size: 9px; font-weight: 700; color: #8E8E93; text-transform: uppercase; display: block; }
.price-tag { font-size: 18px; font-weight: 700; color: #1C1C1E; letter-spacing: -0.5px; }

.card-actions { display: flex; gap: 8px; align-items: center; }
.btn-card-action { width: 32px; height: 32px; border-radius: 50%; border: none; background: #F2F2F7; display: flex; align-items: center; justify-content: center; }

.details-content { max-height: 0; opacity: 0; padding: 0 18px; transition: all 0.4s ease; overflow: hidden; }
.unified-card.expanded .details-content { max-height: 250px; opacity: 1; padding-bottom: 20px; border-top: 1px solid #F3F4F6; padding-top: 15px; }

.footer-grid-card { background: #FFF; border-radius: 32px 32px 0 0; box-shadow: 0 -4px 15px rgba(0,0,0,.05); display: flex; flex-direction: column; flex: 1; margin-top: 12px; overflow: hidden; }
.grid-scroll { flex: 1; overflow: auto; }
table { border-collapse: collapse; width: max-content; font-size: 10px; }
th, td { padding: 12px 8px; text-align: center; border-bottom: 1px solid #F9FAFB; width: 75px; }
th:first-child, td:first-child { width: 150px; position: sticky; left: 0; background: #FFF; text-align: left; font-weight: 700; z-index: 5; border-right: 1px solid #F3F4F6; padding-left: 20px; }
</style>
</head>
<body>

<div class="topbar">
  <button class="ios-btn-float" onclick="history.back()">
    <svg viewBox="0 0 24 24" style="width:18px; height:18px; stroke:#1C1C1E; stroke-width:2.2; fill:none"><path d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
  </button>
  <div class="topbar-copy">
    <div class="breadcrumb"><span class="active">Central de Compras</span></div>
    <div class="autosave-status" id="status-sinc">Sincronizado</div>
  </div>
  <button class="ios-btn-float">
    <svg viewBox="0 0 24 24" style="width:18px; height:18px; stroke:#1C1C1E; stroke-width:2.2; fill:none"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0 M12 8v8 M8 12h8"/></svg>
  </button>
</div>

<div class="main">
  <div class="unified-card" id="mainCard">
    <div class="card-search-section">
      <div class="busca-wrap-ios">
        <svg style="width:16px; height:16px; stroke:#8E8E93; position:absolute; left:12px; fill:none; stroke-width:2.5;" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        <input id="busca-fornecedor" class="busca-input" type="text" placeholder="Buscar Fornecedor..." autocomplete="off">
      </div>
    </div>

    <div class="total-info-section">
      <div onclick="toggleCard()" style="flex-grow: 1; cursor: pointer;">
        <span class="total-label">Total da Compra</span>
        <div style="display:flex; align-items:center">
          <span class="price-tag" id="total-geral">R$ 0,00</span>
          <div id="badge-ganho" class="pill-ganho">0%</div>
        </div>
      </div>
      
      <div class="card-actions">
        <button class="btn-card-action"><svg viewBox="0 0 24 24" style="width:14px; stroke:#1C1C1E; fill:none; stroke-width:2.5;"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6"/></svg></button>
        <button class="btn-card-action" onclick="toggleCard()"><svg viewBox="0 0 24 24" style="width:14px; stroke:#1C1C1E; fill:none; stroke-width:2.5;"><path d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg></button>
      </div>
    </div>

    <div class="details-content">
      <span class="sumario-titulo">Sumário da Compra</span>
      <div class="details-grid">
        <div>
          <div class="detail-item">Data: <input type="date" id="data-ciclo" style="border:none; font-weight:700; font-size:11px;"></div>
          <div class="detail-item">Número: <b id="num-compra">#-----</b></div>
        </div>
        <div>
          <div class="detail-item">Total: <b id="subtotal-card">R$ 0,00</b></div>
          <div class="detail-item">Ganho: <b id="ganho-card" style="color:#10B981">R$ 0,00</b></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="footer-grid-card">
  <div class="grid-scroll">
    <table id="tabela-produtos">
      <thead>
        <tr>
          <th>PRODUTOS</th>
          <th>EST INI</th>
          <th>CT. INI</th>
          <th>QT1</th>
          <th>COMP</th>
          <th>CUST</th>
          <th>MKT</th>
          <th>PM</th>
          <th>T1</th>
          <th>T2</th>
          <th>GAN</th>
        </tr>
      </thead>
      <tbody id="corpo-grid"></tbody>
    </table>
  </div>
</div>

<script>
// LÓGICA DE ATUALIZAÇÃO REVISADA
function atualizarSumario() {
    const linhas = Array.from(document.querySelectorAll('#corpo-grid tr'));
    let somaT1 = 0, somaGAN = 0;
    
    linhas.forEach(tr => {
        // Busca os inputs dentro de cada linha
        const t1Input = tr.querySelector('.col-t1-input');
        const ganInput = tr.querySelector('.col-ganho-input');
        
        somaT1 += parseFloat(t1Input?.value) || 0;
        somaGAN += parseFloat(ganInput?.value) || 0;
    });

    const badgeMargem = document.getElementById('badge-ganho');
    if (badgeMargem) {
        if (somaT1 > 0) {
            const percMargem = (somaGAN / somaT1) * 100;
            badgeMargem.textContent = `${percMargem.toFixed(1)}%`;
            badgeMargem.style.display = 'inline-block';
            
            // Alterna as classes de cor
            if (percMargem < 0) {
                badgeMargem.classList.remove('positivo');
                badgeMargem.classList.add('negativo');
            } else {
                badgeMargem.classList.remove('negativo');
                badgeMargem.classList.add('positivo');
            }
        } else {
            badgeMargem.style.display = 'none';
        }
    }

    // Formatação de valores
    const format = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    document.getElementById('total-geral').textContent = format(somaT1);
    document.getElementById('subtotal-card').textContent = format(somaT1);
    document.getElementById('ganho-card').textContent = format(somaGAN);
}

// Funções de interface
function toggleCard() { document.getElementById('mainCard').classList.toggle('expanded'); }
// Listener de input na tabela para atualizar tempo real
document.getElementById('corpo-grid').addEventListener('input', atualizarSumario);
</script>
</body>
</html>
