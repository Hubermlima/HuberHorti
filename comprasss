<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>HuberHorti - Compras</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="supabase.js"></script>
<script>
function irDashboard(){
  window.location.href = 'dashboard.html';
}
</script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
/* Mantendo seus estilos originais */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#F7F8FA;color:#1A1D23;min-height:100vh}
.topbar{position:fixed;top:0;left:0;right:0;height:78px;background:#F2F4F8;padding:14px 18px 6px;display:flex;align-items:flex-start;z-index:100}
.back-btn{width:44px;height:44px;border:none;border-radius:999px;background:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(0,0,0,0.1);cursor:pointer}
.main{margin-top:78px;padding:16px 16px 100px}
.cli-wrap{position:relative; margin-bottom: 14px;}
.cli-input{width:100%;padding:14px 44px;background:#fff;border:none;border-radius:999px;font-size:15px;box-shadow:0 10px 30px rgba(0,0,0,.08);outline:none}
.cli-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);width:18px;height:18px;stroke:#9CA3AF;fill:none;stroke-width:2}
.cli-lista{position:absolute;top:100%;left:0;right:0;background:#fff;border-radius:18px;margin-top:8px;max-height:240px;overflow-y:auto;box-shadow:0 10px 30px rgba(0,0,0,.15);z-index:1000;display:none}
.cli-lista.open{display:block}
.ac-item{padding:14px 18px;border-bottom:1px solid #F2F2F7;cursor:pointer}
.ac-item:active{background:#F7F8FA}
.ac-cod{font-size:11px;color:#9CA3AF}
.cli-selected{display:none;padding:12px 14px;background:#fff;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,.08);align-items:center;gap:10px}
/* ... Seus outros estilos de tabela e sumário ... */
</style>
</head>
<body>

<div class="topbar">
  <button class="back-btn" onclick="irDashboard()">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 6 9 12 15 18"/></svg>
  </button>
  <div style="margin-left:14px">
    <div style="font-weight:700;font-size:15px">Central de Compras</div>
    <div id="autosave-status" style="font-size:12px;color:#6B7280">Status: pronto</div>
  </div>
</div>

<div class="main">
  <div id="cli-busca" class="cli-wrap">
    <svg class="cli-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="cli-input" id="cli-input" 
           placeholder="Buscar fornecedor..." 
           oninput="buscarCliente(this.value)" 
           autocomplete="off">
    <div class="cli-lista" id="cli-lista"></div>
  </div>

  <div id="cli-sel" class="cli-selected">
    <div style="flex:1">
      <div id="cli-nome" style="font-weight:600">Nome do Fornecedor</div>
      <div id="cli-meta" style="font-size:11px;color:#9CA3AF">Código: ---</div>
    </div>
    <button onclick="trocarFornecedor()" style="border:none;background:#F2F2F7;padding:8px 12px;border-radius:999px;font-size:12px;font-weight:600">Trocar</button>
  </div>

  </div>

<script>
let fornecedores = [];
let fornecedorSel = null;

// Carregamento inicial dos dados (conforme o seu original)
async function carregarDados() {
  const { data: cli } = await db.from('fornecedores').select('id,codigo,nome').order('nome');
  fornecedores = cli || [];
}

// FUNÇÃO DE BUSCA CORRIGIDA
function buscarCliente(val) {
  const lista = document.getElementById('cli-lista');
  const q = val.toLowerCase().trim();

  if (!q) {
    lista.classList.remove('open');
    lista.innerHTML = '';
    return;
  }

  const filtro = fornecedores.filter(function(f) {
    return (f.nome || '').toLowerCase().includes(q) || 
           (f.codigo || '').toLowerCase().includes(q);
  }).slice(0, 10);

  if (filtro.length === 0) {
    lista.innerHTML = '<div class="ac-item">Nenhum fornecedor encontrado</div>';
  } else {
    lista.innerHTML = filtro.map(function(f) {
      return `<div class="ac-item" onclick='selecionarFornecedor(${JSON.stringify(f)})'>
                <div style="font-weight:600">${f.nome}</div>
                <div class="ac-cod">Código: ${f.codigo || 'S/C'}</div>
              </div>`;
    }).join('');
  }
  lista.classList.add('open');
}

async function selecionarFornecedor(f) {
  fornecedorSel = f;
  
  // Esconde busca e mostra selecionado
  document.getElementById('cli-busca').style.display = 'none';
  document.getElementById('cli-sel').style.display = 'flex';
  
  document.getElementById('cli-nome').textContent = f.nome;
  document.getElementById('cli-meta').textContent = 'Código: ' + (f.codigo || ' ');
  
  // Limpa a lista
  document.getElementById('cli-lista').classList.remove('open');
  document.getElementById('cli-input').value = '';

  // Aqui você pode chamar a sua função original de carregar pedidos anteriores
  // Ex: buscarHistorico();
}

function trocarFornecedor() {
  fornecedorSel = null;
  document.getElementById('cli-busca').style.display = 'block';
  document.getElementById('cli-sel').style.display = 'none';
  setTimeout(() => document.getElementById('cli-input').focus(), 100);
}

// Inicializa
carregarDados();
</script>
</body>
</html>
